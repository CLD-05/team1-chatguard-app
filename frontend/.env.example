# 이 파일을 .env.local 로 복사해 개발자별로 설정한다.
#   cp .env.example .env.local
# .env.local 은 .gitignore 대상이라 커밋되지 않으며, 팀원에게 영향을 주지 않는다.

# Mock 모드 토글
#   true  (기본) : 백엔드 없이 가짜 데이터로 동작
#   false        : 실제 백엔드 호출 (백엔드 서버를 먼저 띄워야 함)
VITE_USE_MOCK=true

# API 서버 주소 (선택)
# 비워두면 상대경로 '/api' 로 호출 → Vite 프록시가 localhost:8080 으로 전달(CORS 불필요, 권장).
# 프록시를 거치지 않고 백엔드로 직접 호출하려면 절대 URL을 지정한다(이 경우 백엔드 CORS 설정 필요).
# VITE_API_URL=http://localhost:8080/api

# WebSocket 서버 주소 (선택)
# 개발 모드 기본값은 ws://127.0.0.1:8080/ws 이다.
# 다른 PC에서 접속 테스트를 할 때는 서버 PC의 내부 IP로 바꾼다.
# VITE_WS_BASE_URL=ws://192.168.0.25:8080/ws
